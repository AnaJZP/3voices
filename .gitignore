# ═══════════════════════════════════════════════════════════════
# .gitignore — Three Voices of Sustainability
# ═══════════════════════════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.so

# ── Virtual environment ──
venv/
.venv/
env/

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ──
.ipynb_checkpoints/

# ── Logs ──
logs/
*.log

# ── Large binary model files (BERTopic ~550 MB each) ──
results/topics/*/bertopic_model_*
results/models/

# ── Embedding caches (~45 MB) ──
data/processed/embeddings_cache/

# ── Large processed data files (>50 MB each) ──
# These are regenerated by the pipeline; raw data is kept.
data/processed/corpus_unified.csv
data/processed/corpus_with_sentiment.csv
data/processed/academic_processed.csv
data/processed/political_processed.csv
data/processed/public_processed.csv
results/sentiment/sentiment_results.csv

# ── Large per-document topic assignments (~17 MB each) ──
results/topics/*/doc_topics_*.csv

# ── BERTopic interactive HTML visualizations (~5 MB each) ──
results/topics/*/viz_*.html

# ── Word document drafts ──
*.docx

# ── Manuscript and article generation (kept private) ──
article/
generate_final_word.py

# ── Third-party JS libraries (vendored, not needed for analysis) ──
lib/

# ── Gemini / agent metadata ──
.agents/
.gemini/

# ── OS artifacts ──
*.tmp
~$*
